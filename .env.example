# Reference template — DO NOT edit this file directly.
# Run 'make setup' to generate .env interactively.
# DO NOT commit .env to version control.

# Internal domain for all services
DOMAIN=infra.home

# Host IP that Docker containers can reach (your server's LAN IP)
HOST_IP=192.168.1.10

# Step CA — internal certificate authority
# AUTO-GENERATED by scripts/init.sh — do not set manually
STEP_CA_FINGERPRINT=

# Authentik — identity provider
# AUTO-GENERATED by setup.sh
AUTHENTIK_SECRET_KEY=
AUTHENTIK_POSTGRES_PASSWORD=

# Forgejo
FORGEJO_POSTGRES_PASSWORD=
# FILL AFTER UI: create OAuth app in Forgejo → Settings → Applications
FORGEJO_ADMIN_TOKEN=
WOODPECKER_FORGEJO_CLIENT=
WOODPECKER_FORGEJO_SECRET=

# Woodpecker CI
WOODPECKER_ADMIN=admin
# AUTO-GENERATED by setup.sh
WOODPECKER_AGENT_SECRET=

# WireGuard
WG_DEFAULT_ADDRESS=10.8.0.x
WG_DEFAULT_DNS=10.8.0.1
# AUTO-GENERATED by setup.sh (bcrypt hash of the password you enter during setup)
WG_PASSWORD_HASH=

# SFTPGo
SFTPGO_ADMIN_PASSWORD=
# FILL AFTER UI: create OIDC app in Authentik → Applications (run 'make configure-oidc')
SFTPGO_OIDC_CLIENT_ID=
SFTPGO_OIDC_CLIENT_SECRET=

# Stalwart Mail
STALWART_ADMIN_PASSWORD=

# Technitium DNS
TECHNITIUM_ADMIN_PASSWORD=

# Radicale
# AUTO-GENERATED by scripts/init.sh (htpasswd entry for admin user)
RADICALE_USERS=

# Grafana
GRAFANA_ADMIN_PASSWORD=
GRAFANA_POSTGRES_PASSWORD=
# FILL AFTER UI: create OIDC app in Authentik → Applications (run 'make configure-oidc')
GRAFANA_OIDC_CLIENT_ID=
GRAFANA_OIDC_CLIENT_SECRET=

# Dendrite (Matrix)
DENDRITE_POSTGRES_PASSWORD=
# Matrix server name (usually same as DOMAIN)
MATRIX_SERVER_NAME=

# Authentik proxy outpost token
# FILL AFTER UI: Authentik → Outposts → create/view token (run 'make configure-oidc')
AUTHENTIK_OUTPOST_TOKEN=
