# Copy this to .env and fill in values before running scripts/init.sh
# DO NOT commit .env to version control

# Internal domain for all services
DOMAIN=infra.local

# Host IP that Docker containers can reach (your server's LAN IP)
HOST_IP=192.168.1.10

# Step CA — internal certificate authority
# Generated by scripts/init.sh — do not set manually
STEP_CA_FINGERPRINT=

# Authentik — identity provider
# Generate with: openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=change-me-generate-random-60-chars
AUTHENTIK_POSTGRES_PASSWORD=change-me-strong-password

# Forgejo
FORGEJO_POSTGRES_PASSWORD=change-me-strong-password
# After first start, create admin token in Forgejo UI and paste here for Woodpecker
FORGEJO_ADMIN_TOKEN=

# Woodpecker CI
# Generate with: openssl rand -hex 32
WOODPECKER_AGENT_SECRET=change-me-generate-random-hex-32

# WireGuard
WG_DEFAULT_ADDRESS=10.8.0.x
WG_DEFAULT_DNS=10.8.0.1
# Web UI password
WG_PASSWORD=change-me-strong-password

# SFTPGo
SFTPGO_ADMIN_PASSWORD=change-me-strong-password

# Stalwart Mail
STALWART_ADMIN_PASSWORD=change-me-strong-password

# Radicale
# htpasswd string — generated by scripts/init.sh
RADICALE_USERS=

# Grafana
GRAFANA_ADMIN_PASSWORD=change-me-strong-password
GRAFANA_POSTGRES_PASSWORD=change-me-strong-password

# Dendrite (Matrix)
DENDRITE_POSTGRES_PASSWORD=change-me-strong-password
# Matrix server name (usually the domain without subdomain)
MATRIX_SERVER_NAME=infra.local
